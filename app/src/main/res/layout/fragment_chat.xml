<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- ================= TOP BAR ================= -->

    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ApexPilot"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <!-- ================= SUGGESTION AREA ================= -->

    <LinearLayout
        android:id="@+id/suggestionContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/inputContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="What can I help you with?"
            android:textSize="18sp"
            android:textColor="#BBBBBB"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/suggestionChips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:chipSpacingHorizontal="12dp"
            app:chipSpacingVertical="12dp"
            app:singleLine="false">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipWeather"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weather today"
                android:textColor="#E2E8F0"
                app:chipBackgroundColor="#1A3A5AFF"
                app:chipStrokeWidth="1dp"
                app:chipStrokeColor="#4D3A5AFF"
                app:rippleColor="#333A5AFF"
                app:chipCornerRadius="24dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:elevation="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Send an email"
                android:textColor="#E2E8F0"
                app:chipBackgroundColor="#1A3A5AFF"
                app:chipStrokeWidth="1dp"
                app:chipStrokeColor="#4D3A5AFF"
                app:rippleColor="#333A5AFF"
                app:chipCornerRadius="24dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:elevation="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Search YouTube"
                android:textColor="#E2E8F0"
                app:chipBackgroundColor="#1A3A5AFF"
                app:chipStrokeWidth="1dp"
                app:chipStrokeColor="#4D3A5AFF"
                app:rippleColor="#333A5AFF"
                app:chipCornerRadius="24dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:elevation="0dp" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipReminder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Set reminder"
                android:textColor="#E2E8F0"
                app:chipBackgroundColor="#1A3A5AFF"
                app:chipStrokeWidth="1dp"
                app:chipStrokeColor="#4D3A5AFF"
                app:rippleColor="#333A5AFF"
                app:chipCornerRadius="24dp"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:elevation="0dp" />

        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

    <!-- ================= CHAT LIST ================= -->

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="12dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/inputContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ================= INPUT BAR ================= -->

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/inputContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="14dp"
        app:cardCornerRadius="30dp"
        app:cardElevation="8dp"
        app:cardBackgroundColor="#121826"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Ask ApexPilot..."
                android:textColor="#FFFFFF"
                android:textColorHint="#9CA3AF"/>

            <ImageButton
                android:id="@+id/micButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/send_button_bg"
                android:src="@drawable/ic_mic"
                android:tint="#FFFFFF"/>

            <ImageButton
                android:id="@+id/sendButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/send_button_bg"
                android:src="@drawable/ic_send"
                android:tint="#FFFFFF"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>